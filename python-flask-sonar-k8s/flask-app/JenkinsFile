pipeline {
  agent {
	docker {
		image 'bresh2411/python-flask-sonar-k8s:v1' 
		args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
	}
  }
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed'
        //git branch: 'main', url: 'https://github.com/reshh2411/ultimate-cicd-demo.git'
      }
    }
    stage('Execution') {
      steps {
        sh 'ls -ltr'
		dir('python-flask-sonar-k8s/flask-app/src/main'){
			sh '''
				pip install --no-cache-dir -r requirements.txt --break-system-packages
                python3 app.py &
			'''
		}
      }
    }
    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://16.171.145.32:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
			dir('python-flask-sonar-k8s/flask-app'){
				sh '''
					/opt/sonar-scanner/bin/sonar-scanner \
						-Dsonar.projectKey=flask-app \
						-Dsonar.sources=. \
						-Dsonar.login=$SONAR_AUTH_TOKEN \
						-Dsonar.host.url=${SONAR_URL}
				'''
			}
        }
      }
    }
    stage('Build and Push Docker Image') {
      environment {
        DOCKER_IMAGE = "bresh2411/ultimate-cicd:${BUILD_NUMBER}"
        // DOCKERFILE_LOCATION = "python-flask-sonar-k8s\flask-app\Dockerfile"
        REGISTRY_CREDENTIALS = credentials('docker-cred')
      }
      steps {
        script {
			dir('python-flask-sonar-k8s/flask-app'){
				sh '''
					docker build -t ${DOCKER_IMAGE} .
				'''
			}
            def dockerImage = docker.image("${DOCKER_IMAGE}")
            docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
                dockerImage.push()
            }
        }
      }
    }
    stage('Update Deployment File') {
        environment {
            GIT_REPO_NAME = "ultimate-cicd-demo"
            GIT_USER_NAME = "reshh2411"
        }
        steps {
            withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                sh '''
					git config --global user.email "bresh2411@gmail.com"
                    git config --global user.name "Reshma B"
                    BUILD_NUMBER=${BUILD_NUMBER}
                    sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" python-flask-sonar-k8s/flask-app-manifests/deployment.yml
                    git add python-flask-sonar-k8s/flask-app-manifests/deployment.yml
                    git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                    git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                '''
            }
        }
    }
  }
}
